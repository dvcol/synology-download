{
  "name": "@dvcol/synology-extension",
  "type": "module",
  "version": "4.0.1",
  "packageManager": "pnpm@10.18.3",
  "description": "A basic synology download station client chrome extension",
  "author": "dvcol",
  "license": "MIT",
  "homepage": "https://github.com/dvcol/synology-download",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvcol/synology-download.git"
  },
  "bugs": "https://github.com/dvcol/synology-download/issues",
  "keywords": [
    "extension",
    "webex",
    "web-extension",
    "synology"
  ],
  "sideEffects": false,
  "main": "./dist/entry/index.js",
  "types": "./dist/types/pages/web/index.d.ts",
  "files": [
    "*.md",
    "LICENSE",
    "dist/_locales",
    "dist/entry",
    "dist/json",
    "dist/types/models/index.d.ts",
    "dist/types/models/task.model.d.ts",
    "dist/types/pages/web/index.d.ts",
    "dist/types/pages/web/mocks",
    "dist/types/pages/web/models",
    "dist/types/pages/web/modules"
  ],
  "web-types": "dist/json/web-types.json",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "prepare": "husky",
    "clear:web": "rimraf dist ",
    "clear:extension": "rimraf build",
    "prep": "esno scripts/prepare.ts",
    "vite:serve": "vite",
    "vite:build": "vite build",
    "vite:build:content": "vite build --config vite.content.config.ts",
    "vite:serve:content": "vite --config vite.content.config.ts",
    "dev:extension": "run-s clear:extension && NODE_ENV=development run-p prep vite:serve vite:serve:content",
    "dev:web": "run-s clear:web && NODE_ENV=development VITE_SOURCEMAP=true VITE_WEB=true run-p prep vite:serve",
    "build:extension": "run-s clear:extension && VITE_TARGET=extension run-p lint:type prep vite:build vite:build:content",
    "build:web": "run-s clear:web && VITE_WEB=true VITE_BASE=/synology-download/ run-p prep lint:type vite:build",
    "serve:web": "pnpm run build:web && VITE_WEB=true VITE_BASE=/synology-download/ vite preview",
    "test:unit": "vitest run --coverage --mode testing",
    "test:watch": "vitest --mode testing",
    "lint:quiet": "eslint src --quiet",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "lint:type": "tsc --build tsconfig.app.json",
    "style": "stylelint 'src/**/*.{css,scss,less,html}'",
    "style:fix": "pnpm style --fix",
    "version": "standard-version --skip.changelog --skip.commit --skip.tag",
    "release": "standard-version",
    "release:changelog": "extract-changelog-release > RELEASE.md"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dvcol/web-extension-utils": "~2.1.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "7.0.0",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@mui/x-data-grid": "^8.28.1",
    "@mui/x-tree-view": "^8.27.2",
    "@reduxjs/toolkit": "^2.11.2",
    "notistack": "^3.0.2",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2",
    "react-transition-group": "^4.4.5",
    "redux": "^5.0.1",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "webext-redux": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@dvcol/eslint-config": "^1.8.6",
    "@dvcol/stylelint-plugin-presets": "^2.1.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@faker-js/faker": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.38",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "chokidar": "^5.0.0",
    "chrome-webstore-upload-cli": "^3.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "esno": "^4.8.0",
    "extract-changelog-release": "^1.0.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "natural-compare-lite": "^1.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "standard-version": "^9.5.0",
    "stylelint": "^17.6.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,svelte,json,md}": [
      "eslint --fix"
    ],
    "*.{css,scss,less,vue,svelte}": [
      "stylelint --fix"
    ]
  }
}
